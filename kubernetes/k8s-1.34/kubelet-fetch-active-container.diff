+// FindActiveContainerStatusByName returns the status of a container in the
+// active (current) sandbox with the given name. Unlike FindContainerStatusByName,
+// this only searches ActiveContainerStatuses, avoiding matches from old sandboxes.
+func (podStatus *PodStatus) FindActiveContainerStatusByName(containerName string) *Status {
+	for _, containerStatus := range podStatus.ActiveContainerStatuses {
+		if containerStatus.Name == containerName {
+			return containerStatus
+		}
+	}
+	return nil
+}
